@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Optional dependencies - find them if they were used at build time
if(@OpenMP_CXX_FOUND@)
    find_dependency(OpenMP)
endif()
if(@CUDAToolkit_FOUND@)
    find_dependency(CUDAToolkit)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/NPCoreTargets.cmake")

check_required_components(NPCore)
